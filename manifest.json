{
  "manifest_version": 3,
  "name": "YomiSaver",
  "version": "1.0.0",
  "description": "Add configurable furigana to Japanese web pages, look up words, save vocabulary with context, and export cards for Anki.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://jisho.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "YomiSaver",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.bundle.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "dict/*.dat.gz"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ]
}